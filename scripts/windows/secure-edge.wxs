<?xml version="1.0" encoding="UTF-8"?>
<!--
  Secure Edge Windows MSI definition.

  This file targets WiX Toolset v4 (heat/candle/light are still
  supported via the wix.exe wrapper or the older 3.x toolchain). It
  installs:
    * the Go agent binary into C:\Program Files\SecureEdge\
    * a default config + rules into ProgramData\SecureEdge\
    * a Windows service registered to start at boot
    * a Start Menu shortcut to the tray app (optional)

  Versions are passed in as preprocessor variables by build-msi.ps1 so
  CI does not have to rewrite this file for every release.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Secure Edge"
    Manufacturer="ShieldNet"
    Version="$(var.ProductVersion)"
    UpgradeCode="6F2A4E29-9E2E-4E3A-9F5E-7C2A2B95D0E1"
    Compressed="yes"
    Scope="perMachine">

    <SummaryInformation Description="Secure Edge — local DNS + DLP agent" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Secure Edge is already installed." />

    <Feature Id="Core" Title="Secure Edge core" Level="1">
      <ComponentGroupRef Id="AgentBinary" />
      <ComponentGroupRef Id="RuleFiles" />
      <ComponentRef Id="ServiceRegistration" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SecureEdge">
        <Directory Id="BIN" Name="bin" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATAFOLDER" Name="SecureEdge">
        <Directory Id="RULESFOLDER" Name="rules" />
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="AgentBinary" Directory="BIN">
      <Component Id="AgentBinaryComponent" Guid="*">
        <File Id="AgentExe"
              Source="$(var.AgentExePath)"
              Name="secure-edge-agent.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="RuleFiles" Directory="RULESFOLDER">
      <!--
        Rule files are added by `heat dir` at build time and referenced
        by ComponentGroupRef above. Keeping the harvested file separate
        avoids manually maintaining hundreds of <File> elements as the
        rules grow.
      -->
    </ComponentGroup>

    <Component Id="ServiceRegistration" Directory="BIN" Guid="*">
      <File Id="ServiceConfig"
            Source="$(var.AgentExePath)"
            Name="secure-edge-agent-service.exe"
            KeyPath="yes" />
      <ServiceInstall
        Id="SecureEdgeService"
        Type="ownProcess"
        Vital="yes"
        Name="SecureEdge"
        DisplayName="Secure Edge"
        Description="Local DNS resolver, policy engine, and DLP scanner for endpoint protection."
        Start="auto"
        Account="LocalSystem"
        ErrorControl="normal" />
      <ServiceControl
        Id="StartSecureEdgeService"
        Start="install"
        Stop="both"
        Remove="uninstall"
        Name="SecureEdge"
        Wait="yes" />
    </Component>
  </Package>
</Wix>
