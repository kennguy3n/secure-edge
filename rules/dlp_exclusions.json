{
  "exclusions": [
    {
      "applies_to": "*",
      "type": "dictionary",
      "words": [
        "placeholder",
        "example",
        "test",
        "dummy",
        "sample",
        "xxx",
        "your-",
        "your_",
        "fake",
        "redacted",
        "<redacted>",
        "CHANGEME",
        "TODO",
        "documentation",
        "tutorial",
        "mock"
      ],
      "window": 50,
      "match_type": "proximity"
    },
    {
      "applies_to": "AWS Access Key",
      "type": "dictionary",
      "words": [
        "AKIAIOSFODNN7EXAMPLE",
        "AKIA1234567890123456"
      ],
      "match_type": "exact"
    },
    {
      "applies_to": "AWS Secret Access Key",
      "type": "regex",
      "pattern": "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY",
      "suppress": true
    },
    {
      "applies_to": "AWS Session Token",
