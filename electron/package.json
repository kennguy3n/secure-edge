{
  "name": "secure-edge-tray",
  "version": "0.1.0",
  "private": true,
  "description": "Secure Edge tray app — minimal Electron shell that talks to the Go agent over localhost HTTP.",
  "homepage": "https://github.com/kennguy3n/secure-edge",
  "author": {
    "name": "ShieldNet (Secure Edge)",
    "email": "kennguy3n@users.noreply.github.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.5",
    "vite": "^8.0.12"
  }
}
